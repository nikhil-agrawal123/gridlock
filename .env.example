# Copy to .env and fill in. The .env file is gitignored.

# TomTom Traffic API key -- needed for live corridor speeds.
# Create one at https://developer.tomtom.com/ and make sure the key's
# product list includes "Traffic API" (Flow Segment Data). Without a key
# the app falls back to a deterministic mock (responses are flagged
# tomtom_is_mock=true).
TOMTOM_API_KEY=your_key_here
